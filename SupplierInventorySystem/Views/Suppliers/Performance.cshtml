@model IEnumerable<SupplierInventorySystem.ViewModels.SupplierPerformanceDto>
@{
    ViewData["Title"] = "ביצועי ספקים";
    var totalSpend = Model.Sum(p => p.TotalPurchased);
    var avgOnTime = Model.Where(p => p.ReceivedOrders > 0).Any()
        ? Math.Round(Model.Where(p => p.ReceivedOrders > 0).Average(p => p.OnTimeRate), 1)
        : 0m;
    var topSupplier = Model.FirstOrDefault();
    int activeWithOrders = Model.Count(p => p.TotalOrders > 0);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📊 דשבורד ביצועי ספקים</h2>
    <a asp-action="ExportPerformance" class="btn btn-success">
        <i class="fas fa-file-excel"></i> יצוא Excel
    </a>
</div>

@* כרטיסי סיכום *@
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary">
            <div class="card-body text-center">
                <h3 class="card-title">@Model.Count()</h3>
                <p class="card-text">ספקים פעילים</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info">
            <div class="card-body text-center">
                <h3 class="card-title">@Model.Sum(p => p.TotalOrders)</h3>
                <p class="card-text">סה"כ הזמנות</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white @(avgOnTime >= 90 ? "bg-success" : avgOnTime >= 70 ? "bg-warning" : "bg-danger")">
            <div class="card-body text-center">
                <h3 class="card-title">@(avgOnTime)%</h3>
                <p class="card-text">אחוז אספקה בזמן (ממוצע)</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-dark">
            <div class="card-body text-center">
                <h3 class="card-title">₪@totalSpend.ToString("N0")</h3>
                <p class="card-text">סה"כ רכישות</p>
            </div>
        </div>
    </div>
</div>

@* טבלת ביצועים *@
<div class="card shadow-sm">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">ביצועים לפי ספק</h5>
    </div>
    <div class="card-body p-0">
        <table class="table table-bordered table-hover mb-0">
            <thead class="thead-dark">
                <tr>
                    <th>ספק</th>
                    <th class="text-center">דירוג</th>
                    <th class="text-center">הזמנות</th>
                    <th class="text-center">התקבלו</th>
                    <th class="text-center">אספקה בזמן</th>
                    <th class="text-center">עיכוב ממוצע</th>
                    <th class="text-center">סה"כ רכישות</th>
                    <th class="text-center">ממוצע הזמנה</th>
                    <th class="text-center">פגמים (ידני)</th>
                    <th class="text-center">פעולות</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>
                            <strong>@p.SupplierName</strong>
                            @if (!string.IsNullOrEmpty(p.SupplierCode))
                            {
                                <br /><small class="text-muted">@p.SupplierCode</small>
                            }
                        </td>
                        <td class="text-center">
                            @if (p.Rating.HasValue)
                            {
                                <span class="badge badge-warning text-dark">⭐ @p.Rating.Value.ToString("0.0")</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="text-center">
                            <span class="badge badge-secondary">@p.TotalOrders</span>
                        </td>
                        <td class="text-center">
                            <span class="badge badge-info">@p.ReceivedOrders</span>
                        </td>
                        <td class="text-center">
                            @if (p.ReceivedOrders > 0)
                            {
                                <div class="progress" style="height:20px; min-width:80px;">
                                    <div class="progress-bar bg-@p.OnTimeRateClass"
                                         role="progressbar"
                                         style="width:@(p.OnTimeRate)%"
                                         title="@(p.OnTimeRate)%">
                                        @(p.OnTimeRate)%
                                    </div>
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">אין נתונים</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (p.ReceivedOrders > 0)
                            {
                                var delayClass = p.AvgDelayDays <= 0 ? "success" : p.AvgDelayDays <= 3 ? "warning" : "danger";
                                <span class="badge badge-@delayClass">@p.AvgDelayLabel</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="text-center">
                            <strong>₪@p.TotalPurchased.ToString("N0")</strong>
                        </td>
                        <td class="text-center">
                            @if (p.TotalOrders > 0)
                            {
                                <span>₪@p.AvgOrderValue.ToString("N0")</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (p.ManualDefectRate.HasValue)
                            {
                                var pct = Math.Round(p.ManualDefectRate.Value * 100, 1);
                                var badgeClass = pct <= 1 ? "success" : pct <= 3 ? "warning" : "danger";
                                <span class="badge badge-@badgeClass">@pct%</span>
                                if (p.LastMetricDate.HasValue)
                                {
                                    <br /><small class="text-muted">@p.LastMetricDate.Value.ToString("MM/yyyy")</small>
                                }
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-controller="Suppliers" asp-action="Details" asp-route-id="@p.SupplierId"
                               class="btn btn-sm btn-outline-primary">פרטים</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3 text-muted small">
    <strong>מקרא:</strong>
    <span class="badge badge-success ml-2">90%+ בזמן ✓</span>
    <span class="badge badge-warning ml-2">70-89% בזמן</span>
    <span class="badge badge-danger ml-2">מתחת ל-70%</span>
    <span class="badge badge-secondary ml-2">אין הזמנות שהתקבלו</span>
</div>
