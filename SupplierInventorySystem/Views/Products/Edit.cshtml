@model SupplierInventorySystem.Models.Product
@using Microsoft.AspNetCore.Mvc.Rendering
@using System
@{
    ViewData["Title"] = "עריכת מוצר";
    var categoryList = ViewData["CategoryId"] as SelectList;
    var unitList = ViewData["DefaultUnitId"] as SelectList;
}

<h2>עריכת מוצר</h2>

<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Sku"></label>
                <input asp-for="Sku" class="form-control" />
                <span asp-validation-for="Sku" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Name"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description"></label>
                <textarea asp-for="Description" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-row">
                <div class="form-group col-md-6">
                    <label asp-for="CategoryId">קטגוריה</label>
                    <select asp-for="CategoryId" class="form-control" asp-items="@(categoryList)"></select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="form-group col-md-6">
                    <label asp-for="DefaultUnitId">יחידת ברירת מחדל</label>
                    <select asp-for="DefaultUnitId" class="form-control" asp-items="@(unitList)"></select>
                    <span asp-validation-for="DefaultUnitId" class="text-danger"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group col-md-4">
                    <div class="form-check">
                        <input asp-for="IsService" class="form-check-input" />
                        <label asp-for="IsService" class="form-check-label"></label>
                    </div>
                </div>
                <div class="form-group col-md-4">
                    <div class="form-check">
                        <input asp-for="TrackSerials" class="form-check-input" />
                        <label asp-for="TrackSerials" class="form-check-label"></label>
                    </div>
                </div>
                <div class="form-group col-md-4">
                    <div class="form-check">
                        <input asp-for="TrackLots" class="form-check-input" />
                        <label asp-for="TrackLots" class="form-check-label"></label>
                    </div>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group col-md-6">
                    <label asp-for="ReorderPoint"></label>
                    <input asp-for="ReorderPoint" step="0.0001" class="form-control" />
                    <span asp-validation-for="ReorderPoint" class="text-danger"></span>
                </div>
                <div class="form-group col-md-6">
                    <label asp-for="ReorderQty"></label>
                    <input asp-for="ReorderQty" step="0.0001" class="form-control" />
                    <span asp-validation-for="ReorderQty" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group form-check">
                <input asp-for="Active" class="form-check-input" />
                <label asp-for="Active" class="form-check-label">פעיל</label>
            </div>

            <button type="submit" class="btn btn-primary">שמור</button>
            <a asp-action="Index" class="btn btn-secondary">בטל</a>
        </form>
    </div>
</div>

<!-- Image Gallery Management Section -->
<div class="row mt-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-images"></i> ניהול תמונות</h5>
                <div>
                    <button type="button" class="btn btn-sm btn-danger d-none" id="btnDeleteSelected"
                            onclick="deleteSelectedImages()">
                        <i class="fas fa-trash"></i> מחק נבחרים (<span id="selectedCount">0</span>)
                    </button>
                </div>
            </div>
            <div class="card-body">
                <!-- Upload Area -->
                <div class="upload-area" id="imageUploadArea">
                    <input type="file" id="imageFileInput" multiple accept="image/*" style="display:none;" />
                    <div class="upload-prompt" id="uploadPrompt">
                        <i class="fas fa-cloud-upload-alt fa-3x text-primary mb-2"></i>
                        <p class="mb-1">גרור תמונות לכאן או לחץ לבחירה</p>
                        <small class="text-muted">נתמכים: JPG, PNG, GIF, WEBP | מקס: 5MB לקובץ</small>
                        <br />
                        <button type="button" class="btn btn-primary mt-2" onclick="document.getElementById('imageFileInput').click()">
                            <i class="fas fa-plus"></i> בחר תמונות
                        </button>
                    </div>
                    <!-- Progress bar -->
                    <div class="progress d-none mt-3" id="uploadProgress">
                        <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%"></div>
                    </div>
                </div>

                <!-- Upload Messages -->
                <div id="uploadMessages" class="mt-2"></div>

                <!-- Existing Images Grid -->
                <div id="imagesGrid" class="row mt-3 g-3">
                    @if (Model?.ProductImages != null)
                    {
                        @foreach (var image in Model.ProductImages.OrderBy(i => i.DisplayOrder))
                        {
                            <div class="col-6 col-md-4 col-lg-3 image-grid-item" data-image-id="@image.Id">
                                <div class="card h-100 @(image.IsPrimary ? "border-primary border-2" : "")">
                                    <div class="position-relative">
                                        <input type="checkbox" class="image-checkbox position-absolute"
                                               style="top: 8px; right: 8px; z-index: 2; width: 20px; height: 20px;"
                                               onchange="updateSelectedCount()" />
                                        <img src="@image.ThumbPath" class="card-img-top"
                                             alt="@image.OriginalFileName"
                                             style="height: 180px; object-fit: cover; cursor: pointer;"
                                             onclick="openLightbox('@image.FilePath')" />
                                        @if (image.IsPrimary)
                                        {
                                            <span class="badge bg-primary position-absolute" style="top: 8px; left: 8px;">
                                                <i class="fas fa-star"></i> ראשית
                                            </span>
                                        }
                                    </div>
                                    <div class="card-body p-2 text-center">
                                        <small class="text-muted text-truncate d-block">@image.OriginalFileName</small>
                                        <small class="text-muted">@((image.FileSize / 1024.0).ToString("0.0")) KB</small>
                                        <div class="mt-1">
                                            @if (!image.IsPrimary)
                                            {
                                                <button type="button" class="btn btn-sm btn-outline-primary"
                                                        onclick="setPrimary(@Model.Id, @image.Id)"
                                                        title="הגדר כתמונה ראשית">
                                                    <i class="fas fa-star"></i>
                                                </button>
                                            }
                                            <button type="button" class="btn btn-sm btn-outline-danger"
                                                    onclick="deleteSingleImage(@image.Id)"
                                                    title="מחק תמונה">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Lightbox Modal -->
<div class="modal fade" id="imageLightbox" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content bg-dark">
            <div class="modal-header border-0">
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-0">
                <img id="lightboxImage" src="" class="img-fluid" style="max-height: 85vh;" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/product-images.js"></script>
    <script>
        var productId = @Model.Id;
        var antiForgeryToken = '@Html.AntiForgeryToken()';
        // Extract the token value
        var tokenMatch = antiForgeryToken.match(/value="([^"]+)"/);
        var tokenValue = tokenMatch ? tokenMatch[1] : '';

        initImageUpload(productId, tokenValue);
    </script>
}
